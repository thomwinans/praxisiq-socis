@* Compact profile card for member lists, search results *@

<MudCard Elevation="1" Class="pa-3" Style="cursor:pointer;" @onclick="OnClick">
    <MudCardContent Class="d-flex align-center gap-3 pa-0">
        <MudAvatar Color="Color.Primary" Size="Size.Large">
            @if (!string.IsNullOrEmpty(PhotoUrl))
            {
                <MudImage Src="@PhotoUrl" Alt="@DisplayName" />
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Person" />
            }
        </MudAvatar>
        <div>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.subtitle1">@DisplayName</MudText>
                @if (ShowReputation)
                {
                    <ReputationBadge OverallScore="@ReputationScore"
                                     ReferralScore="@RepReferralScore"
                                     ContributionScore="@RepContributionScore"
                                     AttestationScore="@RepAttestationScore" />
                }
            </MudStack>
            @if (!string.IsNullOrEmpty(Specialty))
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@Specialty</MudChip>
            }
            @if (!string.IsNullOrEmpty(Geography))
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Geography</MudText>
            }
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public string DisplayName { get; set; } = string.Empty;
    [Parameter] public string? Specialty { get; set; }
    [Parameter] public string? Geography { get; set; }
    [Parameter] public string? PhotoUrl { get; set; }
    [Parameter] public bool ShowReputation { get; set; }
    [Parameter] public decimal ReputationScore { get; set; }
    [Parameter] public decimal RepReferralScore { get; set; }
    [Parameter] public decimal RepContributionScore { get; set; }
    [Parameter] public decimal RepAttestationScore { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
}
