@inject INetworkService NetworkService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Apply to @NetworkName</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string"
                      @bind-Value="_applicationText"
                      Label="Why would you like to join?"
                      Lines="4"
                      MaxLength="1000"
                      Counter="1000"
                      Variant="Variant.Outlined"
                      HelperText="Tell the network stewards about yourself and why you'd like to join." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SubmitAsync"
                   Disabled="_submitting">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Submit Application
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string NetworkId { get; set; } = string.Empty;

    [Parameter]
    public string NetworkName { get; set; } = string.Empty;

    private string? _applicationText;
    private bool _submitting;

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        _submitting = true;
        var success = await NetworkService.ApplyAsync(NetworkId, _applicationText);
        if (success)
        {
            MudDialog.Close(DialogResult.Ok(true));
        }
        _submitting = false;
    }
}
