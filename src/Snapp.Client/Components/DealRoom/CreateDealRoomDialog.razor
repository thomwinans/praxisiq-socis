@inject IDealRoomService DealRoomService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">New Deal Room</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string"
                      @bind-Value="_name"
                      Label="Deal Room Name"
                      MaxLength="200"
                      Counter="200"
                      Variant="Variant.Outlined"
                      Required="true"
                      RequiredError="Name is required"
                      Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SubmitAsync"
                   Disabled="@(!CanSubmit || _submitting)">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private string _name = string.Empty;
    private bool _submitting;

    private bool CanSubmit => !string.IsNullOrWhiteSpace(_name);

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        if (!CanSubmit) return;

        _submitting = true;
        var request = new CreateDealRoomRequest { Name = _name.Trim() };
        var result = await DealRoomService.CreateAsync(request);
        if (result is not null)
            MudDialog.Close(DialogResult.Ok(true));
        _submitting = false;
    }
}
