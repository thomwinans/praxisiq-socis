@page "/intelligence"
@attribute [Authorize]
@using MudBlazor
@using Snapp.Client.Components.Intelligence
@using Snapp.Client.Services
@using Snapp.Shared.DTOs.Intelligence
@inject IIntelligenceService IntelligenceService
@inject NavigationManager Navigation

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Practice Intelligence</MudText>
    @if (_progression is not null && _progression.TotalAnswered > 0)
    {
        <ProgressionIndicator TotalUnlocks="@_progression.TotalUnlocks"
                              TotalAnswered="@_progression.TotalAnswered"
                              CurrentStreak="@_progression.CurrentStreak" />
    }
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else if (_error)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        Failed to load dashboard data.
        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="LoadDashboardAsync">Retry</MudButton>
    </MudAlert>
}
else if (_dashboard is not null)
{
    @* Valuation Hero *@
    @if (_dashboard.ValuationSummary is not null)
    {
        var val = _dashboard.ValuationSummary;
        <MudPaper Elevation="2" Class="pa-6 mb-6">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Practice Valuation Range</MudText>
            <MudStack Row="true" Justify="Justify.SpaceEvenly" AlignItems="AlignItems.Center">
                <MudStack AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.caption">Downside</MudText>
                    <MudText Typo="Typo.h6">@FormatCurrency(val.Downside)</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.Remove" Size="Size.Small" />
                <MudStack AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.caption" Color="Color.Primary">Base</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary"><b>@FormatCurrency(val.Base)</b></MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.Remove" Size="Size.Small" />
                <MudStack AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.caption">Upside</MudText>
                    <MudText Typo="Typo.h6">@FormatCurrency(val.Upside)</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Class="mb-6">
            Contribute practice data to unlock your valuation estimate.
            <MudButton Variant="Variant.Text" Color="Color.Info" Href="/intelligence/contribute">Get Started</MudButton>
        </MudAlert>
    }

    @* Question Card *@
    @if (_currentQuestion is not null && !_allCaughtUp)
    {
        <QuestionCard Question="@_currentQuestion"
                      OnAnswered="HandleQuestionAnswered"
                      OnSkipped="HandleQuestionSkipped" />
    }
    else if (_allCaughtUp)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4" Dense="true">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" />
            All caught up! No pending questions right now.
        </MudAlert>
    }

    @* Main Grid *@
    <MudGrid>
        @* Scoring Dimensions Chart *@
        <MudItem xs="12" md="6">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-2">Scoring Dimensions</MudText>
                @if (_score?.DimensionScores.Any() == true)
                {
                    <MudChart ChartType="ChartType.Donut"
                              InputData="@_dimensionValues"
                              InputLabels="@_dimensionLabels"
                              Width="300px" Height="300px" />
                }
                else
                {
                    <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Large" Color="Color.Default" />
                        <MudText Color="Color.Default">No scores computed yet</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/intelligence/contribute">
                            Contribute Data
                        </MudButton>
                    </MudStack>
                }
            </MudPaper>
        </MudItem>

        @* KPI Grid *@
        <MudItem xs="12" md="6">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-2">Key Performance Indicators</MudText>
                @if (_dashboard.KPIs.Any())
                {
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th>Metric</th>
                                <th>Value</th>
                                <th>Trend</th>
                                <th>Percentile</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kpi in _dashboard.KPIs)
                            {
                                <tr>
                                    <td>@kpi.Name</td>
                                    <td>@FormatKpiValue(kpi)</td>
                                    <td>
                                        <MudIcon Icon="@GetTrendIcon(kpi.Trend)"
                                                 Color="@GetTrendColor(kpi.Trend)"
                                                 Size="Size.Small" />
                                    </td>
                                    <td>
                                        @if (kpi.Percentile.HasValue)
                                        {
                                            <MudText Typo="Typo.body2">@($"{kpi.Percentile.Value:F0}th")</MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Default">--</MudText>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
                else
                {
                    <MudText Color="Color.Default" Class="pa-4">No KPIs available. Contribute data to see your metrics.</MudText>
                }
            </MudPaper>
        </MudItem>

        @* Confidence Bar *@
        <MudItem xs="12" md="4">
            <MudCard>
                <MudCardContent>
                    <ConfidenceBar Score="@_dashboard.ConfidenceScore" />
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* Career Stage *@
        <MudItem xs="12" md="4">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2">Career Stage</MudText>
                    @if (_careerStage is not null)
                    {
                        <MudText Typo="Typo.h6" Class="mt-2">@_careerStage.DisplayName</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@GetConfidenceLevelColor(_careerStage.ConfidenceLevel)" Class="mt-1">
                            @_careerStage.ConfidenceLevel confidence
                        </MudChip>
                        @if (_careerStage.RiskFlags.Any(r => r.Severity == "high"))
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                                @(_careerStage.RiskFlags.Count(r => r.Severity == "high")) high-severity risk flag(s)
                            </MudAlert>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-2">
                            No career stage classification yet.
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* Risk Flags *@
        <MudItem xs="12" md="4">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2">Risk Flags</MudText>
                    @if (_careerStage?.RiskFlags.Any() == true)
                    {
                        <MudList T="RiskFlagResponse" Dense="true" Class="mt-2">
                            @foreach (var flag in _careerStage.RiskFlags)
                            {
                                <MudListItem T="RiskFlagResponse" Icon="@GetRiskIcon(flag.Severity)" IconColor="@GetRiskColor(flag.Severity)">
                                    @flag.Description
                                </MudListItem>
                            }
                        </MudList>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Success" Class="mt-2">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" /> No active risk flags
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* Action Buttons *@
    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4">
        @if (_dashboard.ConfidenceScore < 65)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Href="/intelligence/contribute">
                Contribute Data
            </MudButton>
        }
        <MudLink Href="/intelligence/benchmark">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.BarChart">
                View Benchmarks
            </MudButton>
        </MudLink>
    </MudStack>
}

@code {
    private DashboardResponse? _dashboard;
    private ScoreResponse? _score;
    private CareerStageResponse? _careerStage;
    private ProgressionResponse? _progression;
    private List<QuestionItem> _pendingQuestions = new();
    private QuestionItem? _currentQuestion;
    private int _questionIndex;
    private bool _allCaughtUp;
    private bool _loading = true;
    private bool _error;

    private double[] _dimensionValues = Array.Empty<double>();
    private string[] _dimensionLabels = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        _loading = true;
        _error = false;
        StateHasChanged();

        try
        {
            _dashboard = await IntelligenceService.GetDashboardAsync();
            _score = await IntelligenceService.GetScoreAsync();

            // Career stage may not exist yet — that's okay
            try { _careerStage = await IntelligenceService.GetCareerStageAsync(); } catch { }

            // Load questions and progression — non-critical
            try
            {
                var questionsResponse = await IntelligenceService.GetPendingQuestionsAsync();
                if (questionsResponse?.Questions.Any() == true)
                {
                    _pendingQuestions = questionsResponse.Questions;
                    _questionIndex = 0;
                    _currentQuestion = _pendingQuestions[0];
                }
            }
            catch { }

            try { _progression = await IntelligenceService.GetProgressionAsync(); } catch { }

            if (_score?.DimensionScores.Any() == true)
            {
                _dimensionLabels = _score.DimensionScores.Keys.ToArray();
                _dimensionValues = _score.DimensionScores.Values.Select(v => (double)v).ToArray();
            }

            if (_dashboard is null) _error = true;
        }
        catch
        {
            _error = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task HandleQuestionAnswered(AnswerQuestionResponse? result)
    {
        // Update progression from answer response
        if (result?.Progression is not null)
        {
            _progression = new ProgressionResponse
            {
                TotalAnswered = result.Progression.TotalAnswered,
                TotalUnlocks = result.Progression.TotalUnlocks,
                CurrentStreak = result.Progression.CurrentStreak,
            };
        }

        // Brief delay to show success feedback before advancing
        await Task.Delay(1500);
        AdvanceToNextQuestion();
    }

    private void HandleQuestionSkipped()
    {
        AdvanceToNextQuestion();
    }

    private void AdvanceToNextQuestion()
    {
        _questionIndex++;
        if (_questionIndex < _pendingQuestions.Count)
        {
            _currentQuestion = _pendingQuestions[_questionIndex];
        }
        else
        {
            _currentQuestion = null;
            _allCaughtUp = true;
        }
        StateHasChanged();
    }

    private static string FormatCurrency(decimal value)
        => value >= 1_000_000 ? $"${value / 1_000_000:F1}M" : $"${value:N0}";

    private static string FormatKpiValue(KpiItem kpi)
    {
        if (string.IsNullOrEmpty(kpi.Unit)) return kpi.Value;
        return kpi.Unit switch
        {
            "USD" => $"${kpi.Value}",
            "%" => $"{kpi.Value}%",
            _ => $"{kpi.Value} {kpi.Unit}",
        };
    }

    private static string GetTrendIcon(string trend) => trend switch
    {
        "Up" => Icons.Material.Filled.ArrowUpward,
        "Down" => Icons.Material.Filled.ArrowDownward,
        _ => Icons.Material.Filled.Remove,
    };

    private static Color GetTrendColor(string trend) => trend switch
    {
        "Up" => Color.Success,
        "Down" => Color.Error,
        _ => Color.Default,
    };

    private static Color GetConfidenceLevelColor(string level) => level switch
    {
        "high" => Color.Success,
        "medium" => Color.Warning,
        _ => Color.Error,
    };

    private static string GetRiskIcon(string severity) => severity switch
    {
        "high" => Icons.Material.Filled.Error,
        "medium" => Icons.Material.Filled.Warning,
        _ => Icons.Material.Filled.Info,
    };

    private static Color GetRiskColor(string severity) => severity switch
    {
        "high" => Color.Error,
        "medium" => Color.Warning,
        _ => Color.Info,
    };
}
