@page "/networks/{NetId}"
@attribute [Authorize]
@inject INetworkService NetworkService
@inject NetworkState NetworkState
@inject NavigationManager Navigation

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Class="d-block mx-auto my-8" />
}
else if (_network is null)
{
    <MudAlert Severity="Severity.Error">
        Network not found.
        <MudButton Variant="Variant.Text" Color="Color.Error" Href="/networks">Back to Directory</MudButton>
    </MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">@_network.Name</MudText>

    <MudGrid>
        <MudItem xs="12" md="8">
            <MudCard Elevation="1" Class="mb-4">
                <MudCardHeader>
                    <MudText Typo="Typo.h6">Dashboard</MudText>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0">
                                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" />
                                <MudText Typo="Typo.h5">@_network.MemberCount</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Members</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Large" Color="Color.Secondary" />
                                <MudText Typo="Typo.h5">@_network.CreatedAt.ToString("MMM yyyy")</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Created</MudText>
                            </MudPaper>
                        </MudItem>
                        @if (IsSteward)
                        {
                            <MudItem xs="6" sm="3">
                                <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="0">
                                    <MudBadge Content="@_pendingAppCount" Color="Color.Warning" Visible="@(_pendingAppCount > 0)">
                                        <MudIcon Icon="@Icons.Material.Filled.HowToReg" Size="Size.Large" Color="Color.Warning" />
                                    </MudBadge>
                                    <MudText Typo="Typo.h5">@_pendingAppCount</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pending Apps</MudText>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            @if (!string.IsNullOrWhiteSpace(_network.Description))
            {
                <MudCard Elevation="1" Class="mb-4">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6">About</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText>@_network.Description</MudText>
                    </MudCardContent>
                </MudCard>
            }
        </MudItem>

        <MudItem xs="12" md="4">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <MudText Typo="Typo.h6">Quick Links</MudText>
                </MudCardHeader>
                <MudCardContent Class="d-flex flex-column gap-2">
                    <MudButton Variant="Variant.Outlined"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.DynamicFeed"
                               Href="@($"/networks/{NetId}/feed")">
                        Feed
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Forum"
                               Href="@($"/networks/{NetId}/discuss")">
                        Discussions
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.People"
                               Href="@($"/networks/{NetId}/members")">
                        Members
                    </MudButton>
                    @if (IsSteward)
                    {
                        <MudDivider Class="my-1" />
                        <MudButton Variant="Variant.Outlined"
                                   FullWidth="true"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Settings"
                                   Href="@($"/networks/{NetId}/settings")">
                            Settings
                        </MudButton>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter]
    public string NetId { get; set; } = string.Empty;

    private NetworkResponse? _network;
    private bool _loading = true;
    private int _pendingAppCount;

    private bool IsSteward => _network?.UserRole is "steward" or "admin";

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _network = await NetworkService.GetNetworkAsync(NetId);
        if (_network is not null && IsSteward)
        {
            try
            {
                var apps = await NetworkService.GetApplicationsAsync(NetId);
                _pendingAppCount = apps.Count;
            }
            catch
            {
                _pendingAppCount = 0;
            }
        }
        _loading = false;
    }
}
