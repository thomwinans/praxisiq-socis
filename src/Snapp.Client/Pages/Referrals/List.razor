@page "/referrals"
@attribute [Authorize]
@inject IReferralService ReferralService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">Referrals</MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateDialogAsync">
        New Referral
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Class="d-block mx-auto my-8" />
}
else if (_error)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        Failed to load referrals.
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="LoadAsync">Retry</MudButton>
    </MudAlert>
}
else
{
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
        <MudTabPanel Text="Sent" BadgeData="@_sent.Count" BadgeColor="Color.Primary">
            @if (!_sent.Any())
            {
                <MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.SendAndArchive" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.body1" Class="mt-2">No sent referrals yet.</MudText>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Class="mt-4"
                               OnClick="OpenCreateDialogAsync">
                        Send Your First Referral
                    </MudButton>
                </MudPaper>
            }
            else
            {
                @foreach (var referral in _sent)
                {
                    <ReferralCard Referral="referral"
                                  CurrentUserId="@_currentUserId"
                                  OnRecordOutcome="OpenOutcomeDialogAsync"
                                  OnStatusChanged="LoadAsync" />
                }
            }
        </MudTabPanel>

        <MudTabPanel Text="Received" BadgeData="@_received.Count" BadgeColor="Color.Secondary">
            @if (!_received.Any())
            {
                <MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.body1" Class="mt-2">No received referrals yet.</MudText>
                </MudPaper>
            }
            else
            {
                @foreach (var referral in _received)
                {
                    <ReferralCard Referral="referral"
                                  CurrentUserId="@_currentUserId"
                                  OnRecordOutcome="OpenOutcomeDialogAsync"
                                  OnStatusChanged="LoadAsync" />
                }
            }
        </MudTabPanel>
    </MudTabs>
}

@code {
    private List<ReferralResponse> _sent = new();
    private List<ReferralResponse> _received = new();
    private string? _currentUserId;
    private bool _loading = true;
    private bool _error;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst("sub")?.Value;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = false;
        try
        {
            var sentTask = ReferralService.GetSentAsync();
            var receivedTask = ReferralService.GetReceivedAsync();
            await Task.WhenAll(sentTask, receivedTask);
            _sent = sentTask.Result.Referrals;
            _received = receivedTask.Result.Referrals;
        }
        catch
        {
            _error = true;
        }
        _loading = false;
    }

    private async Task OpenCreateDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<CreateReferralDialog>(
            "New Referral",
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Referral sent!", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task OpenOutcomeDialogAsync(ReferralResponse referral)
    {
        var parameters = new DialogParameters<RecordOutcomeDialog>
        {
            { x => x.ReferralId, referral.ReferralId },
            { x => x.ReferralSender, referral.SenderDisplayName },
            { x => x.ReferralReceiver, referral.ReceiverDisplayName },
        };

        var dialog = await DialogService.ShowAsync<RecordOutcomeDialog>(
            "Record Outcome", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Outcome recorded!", Severity.Success);
            await LoadAsync();
        }
    }
}
