@page "/login"
@inject IAuthService AuthService

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mt-16">
    <MudCard Elevation="1" Class="pa-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h4" Align="Align.Center">Sign In</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mt-1">
                    Enter your email to receive a magic login link
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (_sent)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    Check your email for a login link. It may take a moment to arrive.
                </MudAlert>
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@_loading"
                           OnClick="SendAgainAsync">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Send Again
                </MudButton>
            }
            else if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="RetryAsync">
                    Try Again
                </MudButton>
            }
            else
            {
                <MudForm @ref="_form" @bind-IsValid="_isValid">
                    <MudTextField T="string"
                                  @bind-Value="_email"
                                  Label="Email"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  InputType="InputType.Email"
                                  Required="true"
                                  RequiredError="Email is required"
                                  Validation="@(new Func<string, string?>(ValidateEmail))"
                                  Class="mb-4" />

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Disabled="@(!_isValid || _loading)"
                               OnClick="SendMagicLinkAsync">
                        @if (_loading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Send Login Link
                    </MudButton>
                </MudForm>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private MudForm? _form;
    private string _email = string.Empty;
    private bool _isValid;
    private bool _loading;
    private bool _sent;
    private string? _error;

    private string? ValidateEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email))
            return "Email is required";
        if (!email.Contains('@') || !email.Contains('.'))
            return "Enter a valid email address";
        return null;
    }

    private async Task SendMagicLinkAsync()
    {
        _error = null;
        _loading = true;

        try
        {
            await AuthService.RequestMagicLinkAsync(_email);
            _sent = true;
        }
        catch
        {
            // Always show success to prevent email enumeration
            _sent = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SendAgainAsync()
    {
        _loading = true;
        try
        {
            await AuthService.RequestMagicLinkAsync(_email);
        }
        catch
        {
            // Silently handle — already in sent state
        }
        finally
        {
            _loading = false;
        }
    }

    private void RetryAsync()
    {
        _error = null;
        _sent = false;
    }
}
