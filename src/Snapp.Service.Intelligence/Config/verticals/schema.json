{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://praxisiq.com/schemas/vertical-config.json",
  "title": "Vertical Configuration Pack",
  "description": "Schema for SNAPP vertical industry configuration packs",
  "type": "object",
  "required": ["vertical", "displayName", "dimensions", "contributionCategories", "careerStageRules", "benchmarkMetrics", "valuationDrivers", "registrySource", "roleDefinitions"],
  "properties": {
    "vertical": {
      "type": "string",
      "maxLength": 50,
      "pattern": "^[a-z_]+$",
      "description": "Machine-readable vertical identifier"
    },
    "displayName": {
      "type": "string",
      "maxLength": 100,
      "description": "Human-readable vertical name"
    },
    "baseConfidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "default": 40
    },
    "maxConfidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "default": 95
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dimension" }
    },
    "contributionCategories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/contributionCategory" }
    },
    "careerStageRules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/careerStageRule" }
    },
    "benchmarkMetrics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/benchmarkMetric" }
    },
    "valuationDrivers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/valuationDriver" }
    },
    "registrySource": { "$ref": "#/$defs/registrySource" },
    "roleDefinitions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/roleDefinition" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "dimension": {
      "type": "object",
      "required": ["name", "displayName", "weight", "thresholds", "kpis"],
      "properties": {
        "name": { "type": "string", "maxLength": 50 },
        "displayName": { "type": "string", "maxLength": 100 },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "thresholds": {
          "type": "object",
          "required": ["strong", "acceptable", "weak"],
          "properties": {
            "strong": { "type": "number", "minimum": 0, "maximum": 100 },
            "acceptable": { "type": "number", "minimum": 0, "maximum": 100 },
            "weak": { "type": "number", "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": false
        },
        "kpis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "displayName", "unit", "category"],
            "properties": {
              "name": { "type": "string", "maxLength": 50 },
              "displayName": { "type": "string", "maxLength": 100 },
              "unit": { "type": "string", "maxLength": 20 },
              "category": { "type": "string", "maxLength": 50 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "contributionCategory": {
      "type": "object",
      "required": ["category", "dimension", "confidenceWeight", "displayName", "fields"],
      "properties": {
        "category": { "type": "string", "maxLength": 50 },
        "dimension": { "type": "string", "maxLength": 50 },
        "confidenceWeight": { "type": "number", "minimum": 0, "maximum": 1 },
        "displayName": { "type": "string", "maxLength": 100 },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "label", "type", "confidenceWeight"],
            "properties": {
              "name": { "type": "string", "maxLength": 50 },
              "label": { "type": "string", "maxLength": 100 },
              "type": {
                "type": "string",
                "enum": ["currency", "percentage", "integer", "decimal", "boolean", "select", "text"]
              },
              "confidenceWeight": { "type": "number", "minimum": 0, "maximum": 1 },
              "validation": {
                "type": "object",
                "properties": {
                  "min": { "type": "number" },
                  "max": { "type": "number" },
                  "pattern": { "type": "string", "maxLength": 200 },
                  "required": { "type": "boolean" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "careerStageRule": {
      "type": "object",
      "required": ["stage", "displayName", "priority"],
      "properties": {
        "stage": { "type": "string", "maxLength": 50 },
        "displayName": { "type": "string", "maxLength": 100 },
        "priority": { "type": "integer", "minimum": 1, "maximum": 100 },
        "minTenureYears": { "type": "number", "minimum": 0 },
        "maxTenureYears": { "type": "number", "minimum": 0 },
        "minProviderCount": { "type": "integer", "minimum": 0 },
        "maxProviderCount": { "type": "integer", "minimum": 0 },
        "minLocationCount": { "type": "integer", "minimum": 0 },
        "minProductionVolume": { "type": "number", "minimum": 0 },
        "maxOwnerProductionPct": { "type": "number", "minimum": 0, "maximum": 100 },
        "minOwnerProductionPct": { "type": "number", "minimum": 0, "maximum": 100 },
        "requiresCoLocation": { "type": "boolean" },
        "requiresEntityFormation": { "type": "boolean" },
        "requiresSuccessionPlan": { "type": "boolean" },
        "maxCeHoursRecent": { "type": "number", "minimum": 0 },
        "entityTypes": { "type": "array", "items": { "type": "string" } },
        "signals": { "type": "array", "items": { "type": "string" } },
        "riskFlags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "benchmarkMetric": {
      "type": "object",
      "required": ["name", "displayName", "unit", "geographicLevels"],
      "properties": {
        "name": { "type": "string", "maxLength": 50 },
        "displayName": { "type": "string", "maxLength": 100 },
        "unit": { "type": "string", "maxLength": 20 },
        "geographicLevels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["national", "state", "metro", "county", "zip"]
          }
        },
        "aggregationType": {
          "type": "string",
          "enum": ["mean", "median", "ratio", "sum", "count"]
        }
      },
      "additionalProperties": false
    },
    "valuationDriver": {
      "type": "object",
      "required": ["name", "displayName", "impactWeight"],
      "properties": {
        "name": { "type": "string", "maxLength": 50 },
        "displayName": { "type": "string", "maxLength": 100 },
        "impactWeight": { "type": "number", "minimum": -1, "maximum": 1 },
        "category": { "type": "string", "maxLength": 50 }
      },
      "additionalProperties": false
    },
    "registrySource": {
      "type": "object",
      "required": ["type", "displayName", "taxonomyCodes"],
      "properties": {
        "type": { "type": "string", "maxLength": 50 },
        "displayName": { "type": "string", "maxLength": 200 },
        "taxonomyCodes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "endpointUrl": { "type": "string", "maxLength": 500 }
      },
      "additionalProperties": false
    },
    "roleDefinition": {
      "type": "object",
      "required": ["role", "displayName", "isProvider", "isRequired"],
      "properties": {
        "role": { "type": "string", "maxLength": 50 },
        "displayName": { "type": "string", "maxLength": 100 },
        "description": { "type": "string", "maxLength": 500 },
        "isProvider": { "type": "boolean" },
        "isRequired": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
